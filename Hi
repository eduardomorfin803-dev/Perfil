            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            font-weight: 600;
            font-size: 1rem;
        }

        .link-card:active { transform: scale(0.96); }

        /* Estilos por red social */
        .discord { border-left: 6px solid #7289da; }
        .discord:hover { background: rgba(114, 137, 218, 0.2); }

        .roblox { border-left: 6px solid #ffffff; }
