<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: radial-gradient(circle, #1a1a2e 0%, #0f0f1a 100%);
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            width: 90%;
            max-width: 400px;
            text-align: center;
            margin-top: 50px;
        }

        .profile-pic {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 3px solid #4ecca3;
            box-shadow: 0 0 20px #4ecca3;
            margin-bottom: 20px;
        }

        h1 { font-size: 1.5rem; margin-bottom: 30px; letter-spacing: 2px; }

        .link-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 15px;
            text-decoration: none;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.3s, border 0.3s;
            font-weight: bold;
        }

        .link-card:active { transform: scale(0.95); }
        .link-card:hover { border: 1px solid #4ecca3; }

        /* Colores específicos para que resalten */
        .discord { border-left: 5px solid #7289da; }
        .youtube { border-left: 5px solid #ff0000; }
        .roblox { border-left: 5px solid #ffffff; }
        .instagram { border-left: 5px solid #e1306c; }

    </style>
</head>
<body>

    <div class="container">
        <img src="https://via.placeholder.com/150" alt="Avatar" class="profile-pic">
        <h1>MIS REDES</h1>

        <a href="#" class="link-card discord">DISCORD: TuUsuario#0000</a>
        <a href="#" class="link-card youtube">YOUTUBE: Tu Canal</a>
        <a href="#" class="link-card roblox">ROBLOX: Tu Perfil</a>
        <a href="#" class="link-card instagram">INSTAGRAM: @TuUser</a>
        <a href="#" class="link-card instagram">FACEBOOK: Tu Nombre</a>
    </div>

</body>
</html>
